# Campus2Air — Local Development Environment Variables
# Copy this file to .env and fill in your values.
# .env is loaded automatically when running python app.py locally.

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-secret

# ── Database ─────────────────────────────────────────────────────────────────
# Leave DB_ENGINE as "sqlite" for local dev — no extra setup needed.
DB_ENGINE=sqlite
# DATABASE_PATH=carpool.db   # default; change if you want a different location

# ── MySQL (production / optional for local) ──────────────────────────────────
# Only needed if DB_ENGINE=mysql
# MYSQL_HOST=your-mysql-host
# MYSQL_USER=your-mysql-user
# MYSQL_PASSWORD=your-mysql-password
# MYSQL_DATABASE=carpool
# MYSQL_PORT=3306
# MYSQL_SSL=false

# ── SerpApi (optional — flight lookup) ───────────────────────────────────────
# Without this key, flight suggestions are disabled but the app still works.
# SERPAPI_API_KEY=your-serpapi-key

# ── Local dev notes ──────────────────────────────────────────────────────────
# 1. Run: pip install -r requirements.txt
# 2. Run: python app.py   →  http://localhost:8000
# 3. For Google Sign-In locally, add "localhost" to Firebase authorized domains:
#    Firebase Console → Authentication → Settings → Authorized domains → Add domain
